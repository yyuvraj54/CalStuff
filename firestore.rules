rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User document + all sub-collections ──────────────────────────────────
    // Every path under /users/{userId} is locked to the authenticated owner.
    // Firebase Auth UID is the document ID, so no userId can ever read another's data.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Daily nutrition logs  →  users/{uid}/nutrition/{YYYY-MM-DD}
      match /nutrition/{date} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // Streak tracking  →  users/{uid}/streaks/current
      match /streaks/{doc} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Deny everything else by default (Firestore default is deny, but explicit is safer).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
